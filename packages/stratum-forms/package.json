{
    "name": "stratum-forms",
    "description": "Lightweight, project-agnostic form framework for React with per-field subscriptions",
    "version": "1.0.0",
    "license": "MIT",
    "author": "Niklas Wagner <nwa@bytenative.de>",
    "homepage": "https://github.com/wagweb/stratum-forms#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/wagweb/stratum-forms.git",
        "directory": "packages/stratum-forms"
    },
    "bugs": {
        "url": "https://github.com/wagweb/stratum-forms/issues"
    },
    "keywords": [
        "react",
        "react-hook",
        "forms",
        "form-state",
        "validation",
        "useSyncExternalStore"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "prepack": "npm run build"
    },
    "peerDependencies": {
        "react": ">=18.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.10",
        "react": "^19.0.0",
        "tsup": "^8.4.0",
        "typescript": "~5.7.2"
    }
}
